# 邮箱服务
# 可选值: cloudflare / duckmail / cloudmail
EMAIL_PROVIDER=cloudflare

# Cloudflare 自定义邮箱 API
EMAIL_API_URL=https://your-mail-api.example.com
EMAIL_API_TOKEN=replace-with-your-token
EMAIL_DOMAIN=example.com
EMAIL_DOMAINS=example.com,example.org

# DuckMail API
# 公共域名可不填 DUCKMAIL_API_KEY；如果你有 DuckMail 私有域名 API Key，
# 直接填进来即可。
DUCKMAIL_API_URL=https://api.duckmail.sbs
DUCKMAIL_API_KEY=
DUCKMAIL_DOMAIN=
DUCKMAIL_DOMAINS=

# Cloud Mail API (skymail)
# 需要先有 Cloud Mail 管理员账号
# CLOUD_MAIL_DOMAIN 和 CLOUD_MAIL_DOMAINS 二选一填写即可
CLOUD_MAIL_API_URL=https://mail.skymail.ink
CLOUD_MAIL_EMAIL=admin@example.com
CLOUD_MAIL_PASSWORD=your-admin-password
CLOUD_MAIL_DOMAIN=example.com
CLOUD_MAIL_DOMAINS=example.com,example.org

# 可选：注册完成后上传到你自己的 key 池
SERVER_URL=https://your-server.example.com
SERVER_ADMIN_PASSWORD=replace-with-your-admin-password
DEFAULT_UPLOAD=true

# 运行参数
DEFAULT_COUNT=1
DEFAULT_CONCURRENCY=2
DEFAULT_DELAY=10
REGISTER_HEADLESS=true
FIRECRAWL_REGISTER_HEADLESS=true
EMAIL_CODE_TIMEOUT=90
API_KEY_TIMEOUT=20
EMAIL_POLL_INTERVAL=3

# 外置 Turnstile Solver 地址 (Theyka/Turnstile-Solver)
TURNSTILE_SOLVER_URL=http://127.0.0.1:5000
